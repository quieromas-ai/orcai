# Copy to `.env` in this project workspace (same directory as `config.yaml`).
# Loaded by the router for secrets and optional PATH when spawning the agent.

# GitHub PAT for `gh` (if you use GitHub from this workspace)
GH_TOKEN=github_pat_your_token_here

# Ensure agent CLIs are found when the router runs under systemd (minimal PATH).
# Prepend directories where `claude`, `gh`, and `az` are installed, e.g.:
# PATH=/home/you/.local/bin:/usr/local/bin:/usr/bin:/bin

# Multi-agent schema: one bot token pair per agent (names must match config.yaml)
# ENGINEER_SLACK_BOT_TOKEN=xoxb-...
# ENGINEER_SLACK_APP_TOKEN=xapp-...
# REVIEWER_SLACK_BOT_TOKEN=xoxb-...
# REVIEWER_SLACK_APP_TOKEN=xapp-...
