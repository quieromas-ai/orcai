# Copy to `.env` in this directory (`router/.env`).
# Slack tokens for the default single-agent setup (see workspace `config.yaml` for multi-agent env var names).

SLACK_BOT_TOKEN=xoxb-your-bot-token-here
SLACK_APP_TOKEN=xapp-your-app-token-here

# Optional: GitHub CLI (`gh`) uses this when the agent runs issue/PR workflows.
GH_TOKEN=github_pat_your_token_here
